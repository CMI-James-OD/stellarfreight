# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
*.tsbuildinfo

# ── Rust / Cargo ──────────────────────────────────────────────────────────────
target/
**/target-*/
**/*.rs.bk
# Keep contracts/Cargo.lock for reproducible builds
!contracts/Cargo.lock

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
# Keep examples
!.env.example
!frontend/.env.example

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
*.wasm

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.project
.settings/
.classpath

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

